# =============================================================
# DATABASE
# =============================================================
DATABASE_URL="postgresql://agrofinance:password@localhost:5432/agrofinance_dev"

# =============================================================
# AUTH
# Gerar com: openssl rand -base64 64
# =============================================================
JWT_SECRET="change-me-with-at-least-32-random-characters"
JWT_REFRESH_SECRET="change-me-with-another-32-random-characters"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =============================================================
# API
# =============================================================
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# =============================================================
# AWS S3 (ou MinIO em dev)
# =============================================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="agrofinance-files"
# Descomente para usar MinIO localmente
# AWS_ENDPOINT_URL="http://localhost:9000"

# =============================================================
# REDIS (para queues — necessário na V2 com OCR)
# =============================================================
REDIS_URL="redis://localhost:6379"

# =============================================================
# WEB (Next.js)
# =============================================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# =============================================================
# POSTGRES (para docker-compose)
# =============================================================
POSTGRES_USER="agrofinance"
POSTGRES_PASSWORD="password"
POSTGRES_DB="agrofinance_dev"
